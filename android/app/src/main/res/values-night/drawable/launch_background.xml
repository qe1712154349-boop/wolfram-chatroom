<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 先画图标 -->
    <item>
        <bitmap android:src="@mipmap/ic_launcher" android:gravity="center" android:tileMode="clamp" />
    </item>

    <!-- 再画背景（覆盖边缘） -->
    <item>
        <shape>
            <solid android:color="#FDF7F7" />
            <!-- 亮色 -->
        </shape>
    </item>

</layer-list>