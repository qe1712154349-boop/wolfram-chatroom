<?xml
    version="1.0"
    encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.wolfram.lovme">
    <!-- 前台服务必须权限 -->
    <uses-permission
        android:name="android.permission.FOREGROUND_SERVICE"/>
    <uses-permission
        android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC"/>
    <!-- 你的其他权限（相机、存储、通知、电池优化等） -->
    <uses-permission
        android:name="android.permission.WAKE_LOCK"/>
    <uses-permission
        android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS"/>
    <uses-permission
        android:name="android.permission.POST_NOTIFICATIONS"/>
    <uses-permission
        android:name="android.permission.CAMERA"/>
    <uses-permission
        android:name="android.permission.READ_MEDIA_IMAGES"/>
    <!-- 存储权限：移除 maxSdkVersion 限制以便写入公共目录 -->
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"/>
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"/>
    <!-- 相机特性（非必须） -->
    <uses-feature
        android:name="android.hardware.camera"
        android:required="false"/>
    <uses-feature
        android:name="android.hardware.camera.autofocus"
        android:required="false"/>
    <uses-feature
        android:name="android.hardware.camera.flash"
        android:required="false"/>
    <application
        android:label="lovme"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:allowBackup="true"
        android:usesCleartextTraffic="true"
        android:supportsRtl="true"
       android:theme="@style/Theme.MyBunnyApp.Splash">
<!-- 1. 前台服务 Service -->
<service
    android:name="com.pravera.flutter_foreground_task.service.ForegroundService"
    android:enabled="true"
    android:exported="false"
    android:foregroundServiceType="dataSync"
    android:stopWithTask="false"/>

<!-- 2. 广播接收器 -->
<receiver
    android:name="com.pravera.flutter_foreground_task.receiver.ForegroundBroadcastReceiver"
    android:enabled="true"
    android:exported="false"/>

<!-- 3. 通知图标 meta-data -->
<meta-data
    android:name="foreground_icon"
    android:resource="@mipmap/ic_launcher" />
        <!-- 主 Activity -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/Theme.MyBunnyApp.Splash"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- 正常运行时使用的主题 -->
<meta-data
    android:name="io.flutter.embedding.android.NormalTheme"
    android:resource="@style/Theme.MyBunnyApp" />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>
        <!-- Flutter 嵌入元数据 -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2"/>
    </application>
</manifest>

