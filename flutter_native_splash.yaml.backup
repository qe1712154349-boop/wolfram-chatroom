# 修改 flutter_native_splash.yaml
flutter_native_splash:
  color: "#FDF7F7"
  color_dark: "#181818"
  android: true
  ios: true
  fullscreen: false
  android_gravity: center
  ios_content_mode: center
  
  # 添加这一行，使用ic_launcher作为启动图标
  image: assets/splash.png
  
  android_12:
    color: "#FDF7F7"
    color_dark: "#181818"
    # 移除或注释掉 image: null
    # image: null